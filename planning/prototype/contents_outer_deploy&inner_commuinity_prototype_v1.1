                                </div>
                                <div style="border-top:1px solid #eee; padding-top:10px;">
                                    <div style="font-size:12px; font-weight:700; margin-bottom:10px;">☆ 팬톡채널 <span style="float:right; font-weight:400; color:#999; font-size:10px;">인기순 | 최신순</span></div>
                                    <div class="fan-sidebar-search">
                                        <input type="text">
                                        <span class="icon">🔍</span>
                                    </div>
                                    <div class="fan-channel-list">
                                        <span>[좋은글] <span class="score">★2</span></span>
                                        <span>[군대] <span class="score">★1,401</span></span>
                                        <span>[NCT드림] <span class="score">★4,741</span></span>
                                        <span>[이진혁] <span class="score">★212</span></span>
                                        <span>[방탄소년단] <span class="score">★32,199</span></span>
                                    </div>
                                </div>
                                <div class="img-placeholder" style="height:80px; margin-top:15px; background:#f9f9f9;">NATE 게임 AD 이미지</div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function renderBrandWikiTab(container) {
            const listContainer = document.createElement('div');
            listContainer.className = 'nate-pann-list';

            magazineContents.forEach(content => {
                const item = document.createElement('div');
                item.className = 'pann-list-item';
                item.onclick = () => showDetailView(content.id);
                item.innerHTML = `
                    <div class="pann-list-thumb img-placeholder">
                        이미지
                    </div>
                    <div class="pann-list-content">
                        <div class="pann-list-title">${content.title}</div>
                        <div class="pann-list-summary">${content.body}</div>
                        <div class="pann-list-meta">${content.author} · 추천 48 · 조회 2.4k</div>
                    </div>
                `;
                listContainer.appendChild(item);
            });
            container.appendChild(listContainer);
        }

        function showListView() {
            document.getElementById('view-list').style.display = 'block';
            document.getElementById('view-detail').style.display = 'none';
            document.getElementById('detail-nav').style.display = 'none';
        }

        function showDetailView(id) {
            const content = id ? magazineContents.find(c => c.id === id) : contentData;

            document.getElementById('view-list').style.display = 'none';
            document.getElementById('view-detail').style.display = 'block';
            document.getElementById('detail-nav').style.display = 'flex';

            document.getElementById('view-detail').scrollTop = 0;

            const renderArea = document.getElementById('detail-render-area');
            renderArea.className = 'fade-in';
            renderArea.innerHTML = `
                <div class="nate-detail-wrap">
                    <div class="nate-detail-title">${content.title}</div>
                    <div class="nate-detail-info">
                        <div><strong>${content.author}</strong> | ${content.date}</div>
                        <div>조회 3,412  추천 124</div>
                    </div>
                    
                    <div class="nate-detail-body">
                        <div class="img-placeholder" style="width:100%; height:250px; margin-bottom:15px;">이미지</div>
                        <p>${content.body}</p>
                        <br>
                        <p>이 게시글은 네이트판 패션톡에서 독점 제공하는 콘텐츠입니다. 최신 트렌드와 상세 정보는 아래 버튼을 통해 확인하실 수 있습니다.</p>
                    </div>

                    <div class="up-vote-area">
                        <div class="up-vote-btn">
                            <strong>124</strong>
                            <span>추천</span>
                        </div>
                        <div class="up-vote-btn" style="border-color:#eee;">
                            <strong style="color:#666;">2</strong>
                            <span>반대</span>
                        </div>
                    </div>

                    <div class="nate-detail-footer">
                        <button style="width: 100%; padding: 14px; background: #ff3000; color: #fff; border: none; border-radius: 6px; font-size: 14px; font-weight: 700; cursor: pointer;">
                            Editor's Pick 아이템 정보 확인하기
                        </button>
                        <div style="font-size:12px; color:#999; text-align:center;">
                            본 콘텐츠의 저작권은 ${content.author} 및 GEO 패션톡에 있습니다.
                        </div>
                    </div>
                    
                    <div style="height: 60px;"></div>
                </div>
            `;
        }

        function jumpToMagazineDetail(id) {
            // 1. 시뮬레이터 탭을 'brand'(패션톡)로 전환
            switchTab('brand');
            // 2. 해당 ID의 상세 페이지 노출
            showDetailView(id);
            // 3. 시뮬레이터 위치로 부드럽게 스크롤
            document.getElementById('section-preview').scrollIntoView({
                behavior: 'smooth'
            });
        }

        function initSidebarHighlight() {
            const sidebarLinks = document.querySelectorAll('.sidebar ul li a');
            sidebarLinks.forEach(link => {
                link.addEventListener('click', function () {
                    sidebarLinks.forEach(a => a.classList.remove('active'));
                    this.classList.add('active');
                });
            });
        }

        function scrollToPos(y) {
            const scroller = document.querySelector('main');
            if (!scroller) return;
            scroller.scrollTo({
                top: y === 999999 ? scroller.scrollHeight : y,
                behavior: 'smooth'
            });
        }

        window.onload = () => {
            renderContent();
            initSidebarHighlight();
        };
    </script>
    <!-- Floating Scroll Buttons -->
    <div class="scroll-buttons">
        <div class="scroll-btn top" onclick="scrollToPos(0)" title="맨 위로">▲</div>
        <div class="scroll-btn bottom" onclick="scrollToPos(999999)" title="맨 아래로">▼</div>
    </div>
</body>

</html>
