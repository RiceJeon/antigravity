&lt;html lang="ko"&gt;
&lt;head&gt;
&lt;meta charset="utf-8"&gt;
&lt;title&gt;모비튠 - 체크 셔츠 남방&lt;/title&gt;
&lt;script type="application/ld+json"&gt;
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "모비튠 클래식 코튼 체크 셔츠 남방",
