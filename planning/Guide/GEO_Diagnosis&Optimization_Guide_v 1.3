  "brand": {
    "@type": "Brand",
    "name": "모비튠"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://www.mobitune.com/goods/123",
    "priceCurrency": "KRW",
    "price": "35000",
    "availability": "https://schema.org/InStock"
  }
}
&lt;/script&gt;
&lt;/head&gt;
&lt;body&gt;
  &lt;h1&gt;체크 셔츠 남방&lt;/h1&gt;
